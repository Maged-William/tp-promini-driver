config TRACKPOINT_I2C
    bool "I2C TrackPoint driver"
    default y
    depends on I2C
    help
      Driver for reading TrackPoint X/Y data via I2C from a Pro Mini
      configured as an I2C slave.

config TRACKPOINT_SPI
    bool "SPI TrackPoint driver"
    default y
    select SPI
    depends on INPUT
    depends on DT_HAS_TRACKPOINT_SPI_ENABLED
    help
      Driver for reading TrackPoint X/Y data via SPI from a Pro Mini
      configured as an SPI slave.
